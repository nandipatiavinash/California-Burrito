PORT=4000
CLIENT_ORIGIN=http://localhost:3000

# Optional: when set, the API writes to Supabase/Postgres instead of data/incidents.json.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional frontend value only if the API is hosted on a separate domain.
# Leave blank for the default Vercel deployment, where /api runs on the same domain.
VITE_API_URL=
